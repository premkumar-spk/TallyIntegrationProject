@model TallyIntegrationProject.Models.SalesVoucher

<style>
    body {
        background-color: #f4f6f9;
        font-family: Arial, Helvetica, sans-serif;
    }

    .page-title {
        margin-left: 40px;
        margin-top: 30px;
        font-weight: 600;
    }

    .form-container {
        width: 400px;
        background: white;
        padding: 30px;
        margin: 20px 40px;
        border-radius: 8px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        font-weight: 600;
        display: block;
        margin-bottom: 6px;
    }

    input {
        width: 95%;
        padding: 10px;
        border-radius: 5px;
        border: 1px solid #ccc;
        font-size: 14px;
    }

    button {
        background-color: #2f3e4d;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 5px;
        cursor: pointer;
    }

        button:hover {
            background-color: #1f2b38;
        }

    .result {
        margin-left: 40px;
        margin-top: 10px;
        color: green;
    }
</style>

<h2 class="page-title">Create Sales Voucher</h2>

<div class="form-container">

    <form asp-action="CreateSalesVoucher" asp-controller="Voucher" method="post">

        <label>Voucher Date</label>
        <input asp-for="Date" type="text" placeholder="YYYY-MM-DD" />

        <label>Customer Name</label>
        <input asp-for="CustomerName" />

        <label>Item Name</label>
        <input asp-for="ItemName" />

        <label>Amount</label>
        <input asp-for="Amount" />

        <button type="submit">Create Voucher</button>

    </form>

</div>

@if (ViewBag.TallyResponse != null)
{
    <div style="margin-top:20px;padding:15px;background:#eef;border-radius:6px;">
        <h4>Tally Response</h4>
        <pre>@ViewBag.TallyResponse</pre>
    </div>
}
@if (ViewBag.Message != null)
{
    <div style="margin-top:20px;padding:10px;background:#ffe0e0;border-radius:6px;">
        <b>@ViewBag.Message</b>
    </div>
}